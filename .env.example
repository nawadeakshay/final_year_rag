# ============================================================
# HR Policy RAG System - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------
# LLM Provider (Groq - Free LLaMA 3)
# Get your free key at: https://console.groq.com
# ------------------------------------
GROQ_API_KEY=your_groq_api_key_here


# ------------------------------------
# Model Configuration
# ------------------------------------
LLM_MODEL=LLM_MODEL = llama-3.1-8b-instant      # or llama3-8b-8192 for faster/cheaper
LLM_TEMPERATURE=0.1                 # Low temp for deterministic, grounded answers
LLM_MAX_TOKENS=1024

# ------------------------------------
# Embedding Model
# ------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2   # Fast, good quality
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5  # Better quality, slower

# ------------------------------------
# Chunking Strategy
# ------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ------------------------------------
# Retrieval Configuration
# ------------------------------------
HYBRID_DENSE_WEIGHT=0.6
HYBRID_SPARSE_WEIGHT=0.4
INITIAL_RETRIEVAL_K=20
RERANK_TOP_K=5
CONFIDENCE_THRESHOLD=0.3

# ------------------------------------
# Cross-Encoder Re-ranking Model
# ------------------------------------
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ------------------------------------
# Storage Paths
# ------------------------------------
DOCUMENTS_DIR=./documents
VECTOR_STORE_PATH=./vector_store
BM25_INDEX_PATH=./bm25_index.pkl

# ------------------------------------
# API Configuration
# ------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
